@import "tailwindcss";

:root {
  --background: #fdf8f2;
  --foreground: #1f2024;
  --surface: #fffdfb;
  --surface-soft: #f4efe6;
  --muted: #5d5d63;
  --brand: #156f52;
  --brand-dark: #0d4f3b;
  --accent: #ea6f54;
  --line: #e4ddcf;
  --shadow: 0 20px 40px rgba(29, 33, 45, 0.08);
}

@theme inline {
  --color-background: var(--background);
  --color-foreground: var(--foreground);
  --color-surface: var(--surface);
  --color-surface-soft: var(--surface-soft);
  --color-muted: var(--muted);
  --color-brand: var(--brand);
  --color-brand-dark: var(--brand-dark);
  --color-accent: var(--accent);
  --color-line: var(--line);
  --font-sans: var(--font-dm-sans);
  --font-serif: var(--font-fraunces);
}

body {
  background: var(--background);
  color: var(--foreground);
  background-image:
    radial-gradient(circle at 8% 0%, rgba(21, 111, 82, 0.1) 0%, transparent 40%),
    radial-gradient(circle at 92% 3%, rgba(234, 111, 84, 0.12) 0%, transparent 36%);
  font-family: var(--font-dm-sans), sans-serif;
}

.container {
  margin: 0 auto;
  max-width: 1100px;
  padding: 0 1rem;
}

.site-header {
  position: sticky;
  top: 0;
  z-index: 40;
  border-bottom: 1px solid rgba(228, 221, 207, 0.85);
  background: rgba(253, 248, 242, 0.9);
  backdrop-filter: blur(10px);
}

.nav-wrap {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 76px;
  gap: 1rem;
}

.brand {
  display: inline-flex;
  align-items: center;
  gap: 0.6rem;
  font-weight: 700;
  letter-spacing: -0.01em;
}

.brand-mark {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 2.05rem;
  height: 2.05rem;
  border-radius: 999px;
  background: linear-gradient(135deg, var(--brand) 0%, var(--brand-dark) 100%);
  color: #fff;
  font-size: 0.78rem;
  font-weight: 700;
  box-shadow: var(--shadow);
}

.brand-text {
  font-family: var(--font-fraunces), serif;
  font-size: 1.05rem;
}

.nav-links {
  display: flex;
  align-items: center;
  gap: 0.45rem;
  font-weight: 600;
}

.nav-links a {
  border-radius: 999px;
  padding: 0.4rem 0.8rem;
  color: var(--muted);
  transition: 160ms ease;
}

.nav-links a:hover {
  background: color-mix(in srgb, var(--surface-soft) 85%, #fff);
  color: var(--brand-dark);
}

.nav-links a:last-child {
  background: var(--foreground);
  color: #fff;
}

.nav-links a:last-child:hover {
  background: #111218;
  color: #fff;
}

.header-cart {
  position: relative;
}

.cart-trigger {
  display: inline-flex;
  align-items: center;
  gap: 0.42rem;
  border-radius: 999px;
  border: 1px solid var(--line);
  background: #fff;
  color: var(--foreground);
  padding: 0.45rem 0.74rem;
  font-size: 0.9rem;
  font-weight: 700;
  transition: 160ms ease;
}

.cart-trigger:hover {
  transform: translateY(-1px);
  box-shadow: 0 8px 18px rgba(29, 33, 45, 0.12);
}

.cart-trigger:focus-visible {
  outline: 2px solid color-mix(in srgb, var(--brand) 42%, #fff);
  outline-offset: 1px;
}

.cart-icon {
  font-size: 0.72rem;
  border-radius: 999px;
  padding: 0.18rem 0.42rem;
  background: color-mix(in srgb, var(--surface-soft) 88%, #fff);
}

.cart-badge {
  min-width: 1.35rem;
  height: 1.35rem;
  border-radius: 999px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: var(--accent);
  color: #fff;
  font-size: 0.75rem;
}

.cart-badge-pulse {
  animation: badge-pulse 320ms ease;
}

.cart-popover {
  position: absolute;
  right: 0;
  top: calc(100% + 0.55rem);
  width: min(92vw, 23rem);
  border-radius: 1rem;
  border: 1px solid var(--line);
  background: var(--surface);
  box-shadow: 0 22px 40px rgba(29, 33, 45, 0.16);
  padding: 0.9rem;
  z-index: 60;
  animation: cart-pop 170ms ease;
}

.cart-popover-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 0.8rem;
}

.cart-popover-head h3 {
  font-family: var(--font-fraunces), serif;
  font-size: 1.1rem;
}

.cart-popover-head span {
  font-size: 0.78rem;
  color: var(--muted);
}

.cart-preview-list {
  display: grid;
  gap: 0.5rem;
}

.cart-preview-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 0.6rem;
  border: 1px solid var(--line);
  border-radius: 0.76rem;
  background: #fff;
  padding: 0.58rem;
}

.cart-preview-main {
  display: flex;
  align-items: center;
  gap: 0.55rem;
  min-width: 0;
}

.cart-preview-thumb {
  width: 2.35rem;
  height: 2.35rem;
  border-radius: 0.55rem;
  border: 1px solid var(--line);
  object-fit: cover;
  flex-shrink: 0;
}

.cart-preview-thumb-empty {
  background: color-mix(in srgb, var(--surface-soft) 75%, #fff);
}

.cart-preview-name {
  font-size: 0.9rem;
  font-weight: 600;
  max-width: 11rem;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.cart-more-items {
  text-align: center;
  margin-top: 0.2rem;
}

.cart-subtotal {
  margin-top: 0.85rem;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-top: 1px dashed var(--line);
  padding-top: 0.65rem;
  font-size: 0.9rem;
}

@keyframes cart-pop {
  from {
    opacity: 0;
    transform: translateY(-5px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes badge-pulse {
  0% {
    transform: scale(1);
  }
  45% {
    transform: scale(1.18);
  }
  100% {
    transform: scale(1);
  }
}

.main-content {
  padding-top: 1.6rem;
  padding-bottom: 2.6rem;
}

.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 0.8rem;
  padding: 0.64rem 0.95rem;
  font-weight: 600;
  border: 1px solid var(--line);
  background: #fff;
  transition: 180ms ease;
}

.btn-primary {
  background: linear-gradient(135deg, var(--brand) 0%, var(--brand-dark) 100%);
  color: #fff;
  border-color: transparent;
  box-shadow: 0 10px 20px rgba(21, 111, 82, 0.24);
}

.btn-primary:hover {
  transform: translateY(-1px);
  box-shadow: 0 14px 24px rgba(21, 111, 82, 0.28);
}

.btn-danger {
  background: #fff;
  color: #b42318;
}

.card {
  background: var(--surface);
  border: 1px solid var(--line);
  border-radius: 1rem;
  box-shadow: var(--shadow);
}

.field,
.select {
  width: 100%;
  border: 1px solid var(--line);
  border-radius: 0.8rem;
  padding: 0.6rem 0.75rem;
  background: #fff;
}

.field:focus,
.select:focus {
  outline: 2px solid color-mix(in srgb, var(--brand) 30%, #fff);
  outline-offset: 1px;
}

.muted {
  color: var(--muted);
}

.hero-shell {
  position: relative;
  overflow: hidden;
  border-radius: 1.4rem;
  border: 1px solid var(--line);
  background:
    radial-gradient(circle at 20% 8%, rgba(21, 111, 82, 0.14) 0%, transparent 45%),
    radial-gradient(circle at 88% 0%, rgba(234, 111, 84, 0.14) 0%, transparent 30%),
    var(--surface);
  box-shadow: var(--shadow);
}

.eyebrow {
  display: inline-flex;
  align-items: center;
  border: 1px solid rgba(21, 111, 82, 0.2);
  border-radius: 999px;
  padding: 0.25rem 0.62rem;
  color: var(--brand-dark);
  font-size: 0.75rem;
  font-weight: 700;
  letter-spacing: 0.01em;
  background: rgba(21, 111, 82, 0.07);
}

.display-title {
  font-family: var(--font-fraunces), serif;
  font-size: clamp(2rem, 4vw, 3.3rem);
  line-height: 1.08;
  letter-spacing: -0.015em;
}

.soft-panel {
  border-radius: 0.9rem;
  border: 1px solid var(--line);
  background: color-mix(in srgb, var(--surface-soft) 76%, #fff);
}

.stagger-in {
  opacity: 0;
  transform: translateY(12px);
  animation: rise 620ms ease forwards;
}

.stagger-in:nth-child(2) {
  animation-delay: 60ms;
}

.stagger-in:nth-child(3) {
  animation-delay: 120ms;
}

@keyframes rise {
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@media (max-width: 760px) {
  .nav-wrap {
    min-height: 72px;
    flex-wrap: wrap;
    padding-top: 0.4rem;
    padding-bottom: 0.6rem;
  }

  .nav-links {
    width: 100%;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .cart-popover {
    right: auto;
    left: 0;
  }
}

/* ━━━ RESPONSIVE GRID ━━━ */
.responsive-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0.85rem;
}

@media (min-width: 640px) {
  .responsive-grid {
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }
}

@media (min-width: 1024px) {
  .responsive-grid {
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
  }

  .hero-grid {
    grid-template-columns: 1fr 1fr !important;
  }

  .hero-visual {
    display: block !important;
  }

  .trust-grid {
    grid-template-columns: repeat(4, 1fr) !important;
  }
}

@keyframes scroll {
  0% { transform: translateX(0); }
  100% { transform: translateX(-50%); }
}
