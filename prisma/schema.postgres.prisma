generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id              Int         @id @default(autoincrement())
  name            String
  description     String
  price           Decimal     @db.Decimal(10, 2)
  image           String?
  stock           Int
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  images          String[]    @default([])
  category        String?     @default("General")
  longDescription String?
  features        String[]    @default([])
  items           OrderItem[]
  Review          Review[]
}

model Order {
  id               Int            @id @default(autoincrement())
  customerName     String
  customerPhone    String
  customerAddress  String
  status           OrderStatus    @default(PENDING)
  deliveryStatus   DeliveryStatus @default(PENDING)
  paymentStatus    PaymentStatus  @default(PENDING)
  paymentReference String?        @unique
  transactionId    String?        @unique
  total            Decimal        @db.Decimal(10, 2)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  orderNumber      String?        @unique
  customerEmail    String         @default("")
  notes            String?
  items            OrderItem[]

  @@index([customerEmail])
  @@index([orderNumber])
}

model OrderItem {
  id        Int     @id @default(autoincrement())
  orderId   Int
  productId Int
  quantity  Int
  unitPrice Decimal @db.Decimal(10, 2)
  subtotal  Decimal @db.Decimal(10, 2)
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model Review {
  id            Int       @id @default(autoincrement())
  productId     Int
  customerName  String
  customerEmail String?
  orderNumber   String?
  rating        Int
  comment       String
  location      String?
  approved      Boolean?  @default(false)
  createdAt     DateTime? @default(now()) @db.Timestamp(6)
  Product       Product   @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([approved], map: "review_approved_idx")
  @@index([productId], map: "review_product_idx")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model Coupon {
  id          Int       @id @default(autoincrement())
  code        String    @unique
  description String?
  type        String
  value       Decimal   @default(0) @db.Decimal(10, 2)
  minPurchase Decimal?  @default(0) @db.Decimal(10, 2)
  maxUses     Int?
  currentUses Int?      @default(0)
  active      Boolean?  @default(true)
  validFrom   DateTime? @default(now()) @db.Timestamp(6)
  validUntil  DateTime? @db.Timestamp(6)
  createdAt   DateTime? @default(now()) @db.Timestamp(6)
  updatedAt   DateTime? @default(now()) @db.Timestamp(6)

  @@index([active], map: "coupon_active_idx")
  @@index([code], map: "coupon_code_idx")
}

enum OrderStatus {
  PENDING
  PAID
  DELIVERED
  PREPARING
  SHIPPED
  CANCELLED
}

enum DeliveryStatus {
  PENDING
  ON_ROUTE
  DELIVERED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
}
